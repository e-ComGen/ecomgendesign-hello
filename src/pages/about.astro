---
import Base from '../layouts/Base.astro';
---
<Base title="About — e-ComGen Design" description="A small studio shipping SVG asset packs for designers and developers.">
  <section class="max-w-2xl mx-auto px-6 py-20">
    <h1 class="text-4xl font-semibold tracking-tight mb-6">About</h1>
    <div class="prose prose-navy text-navy/80 space-y-4 leading-relaxed">
      <p>
        <span class="font-medium">e-ComGen<span class="text-orange"> Design</span></span> is a small studio shipping SVG asset
        packs for designers and developers — icons, illustrations and UI elements that
        drop straight into Figma, code, or any modern design tool.
      </p>
      <p>
        Every pack is hand-curated for visual consistency, ships in vector source format
        (SVG, kilobytes per file), and includes a no-attribution commercial license — use
        them in client work, paid products, marketing or print without strings attached.
      </p>
      <p>
        New packs ship regularly. Browse the <a href="/packs" class="text-orange hover:underline">catalog</a> or
        check out the <a href="https://ecomgendesign.gumroad.com" class="text-orange hover:underline">Gumroad shop</a>.
      </p>
    </div>
  </section>
</Base>
