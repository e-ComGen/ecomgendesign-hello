---
interface Props { grids: string[]; pack_title?: string }
const { grids, pack_title = "icon pack" } = Astro.props;
---
<section class="max-w-5xl mx-auto px-6 py-14">
  <h2 class="text-2xl font-semibold tracking-tight mb-2">The full inventory</h2>
  <p class="text-navy/60 mb-6 text-sm">Every icon at a glance. Click for full size.</p>
  <div class="grid sm:grid-cols-2 gap-4">
    {grids.map((src, i) => (
      <a href={src} target="_blank" rel="noopener" class="block border border-navy/10 rounded-xl overflow-hidden hover:border-orange transition-colors">
        <picture>
          <source srcset={src.replace(/\.png$/, '.webp')} type="image/webp" />
          <img
            src={src}
            alt={`${pack_title} — full grid preview ${grids.length > 1 ? `(${i + 1}/${grids.length})` : ''}`}
            class="w-full"
            loading="lazy"
            width="1280"
            height="720"
          />
        </picture>
      </a>
    ))}
  </div>
</section>
