---
interface Icon { name: string; label: string }
interface Props {
  free_picks: string[];     // 4 icon names
  icons: Icon[];            // full icon list (for label lookup)
  pack_slug: string;
  default_variant?: string;
  icons_dir: string;
  icons_ext?: 'png' | 'svg';
}
const { free_picks, icons, pack_slug, default_variant, icons_dir, icons_ext = 'png' } = Astro.props;
const variant_path = default_variant ? `/${default_variant}` : '';
const free_zip = `/packs/${pack_slug}/${pack_slug.replace(/-pack$/, '')}-free.zip`;

const labelOf = (n: string) =>
  icons.find((i) => i.name === n)?.label ?? n.replace(/-/g, ' ');
---
<section id="free" class="bg-gradient-to-br from-orange/10 via-bg to-bg border-b-2 border-orange/20 scroll-mt-20">
  <div class="max-w-5xl mx-auto px-6 py-10">
    <div class="flex flex-col lg:flex-row items-center gap-8">
      <div class="flex-1 lg:max-w-md">
        <div class="inline-flex items-center gap-2 px-3 py-1 bg-orange text-white text-xs font-bold uppercase tracking-wider rounded-full mb-4">
          ★ Free sampler
        </div>
        <h2 class="text-2xl sm:text-3xl font-bold tracking-tight mb-3 leading-tight">
          Try 4 icons free — <span class="text-orange">no email required</span>
        </h2>
        <p class="text-navy/70 mb-5 leading-relaxed">
          Real SVG vectors in all 4 color variants (16 files). Use them in
          commercial projects today, no attribution needed. Like the style?
          Get the full pack below.
        </p>
        <a
          href={free_zip}
          download
          class="inline-flex items-center gap-2 bg-navy text-white px-6 py-3 rounded-lg font-semibold hover:bg-navy/90 transition-colors"
        >
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
          Download free ZIP — 16 SVGs
        </a>
        <div class="text-xs text-navy/50 mt-3">No signup · Direct download · 44 KB</div>
      </div>

      <div class="grid grid-cols-2 gap-3 flex-shrink-0">
        {free_picks.map((name) => (
          <div class="w-28 h-28 bg-white border border-navy/10 rounded-xl flex flex-col items-center justify-center p-3 hover:border-orange transition-colors">
            <img
              src={`${icons_dir}${variant_path}/${name}.${icons_ext}`}
              alt={labelOf(name)}
              class="w-12 h-12 mb-1"
              loading="eager"
              draggable={false}
            />
            <span class="text-[10px] text-navy/60 truncate w-full text-center">{labelOf(name)}</span>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
