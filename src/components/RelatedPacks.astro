---
import { getCollection } from 'astro:content';

interface Props { related: string[] }
const { related } = Astro.props;
const all = await getCollection('packs');
const items = related
  .map((slug) => all.find((p) => p.slug === slug))
  .filter(Boolean) as typeof all;
---
{items.length > 0 && (
  <section class="max-w-5xl mx-auto px-6 py-14">
    <h2 class="text-2xl font-semibold tracking-tight mb-6">More packs</h2>
    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
      {items.map((p) => (
        <a href={`/packs/${p.slug}`} class="group bg-white border border-navy/10 rounded-xl overflow-hidden hover:border-orange hover:shadow-sm transition-all">
          <div class="aspect-video overflow-hidden bg-bg/40">
            <img src={p.data.hero_image} alt={p.data.title} class="w-full h-full object-cover group-hover:scale-105 transition-transform" loading="lazy" />
          </div>
          <div class="p-4">
            <div class="font-semibold text-navy text-sm mb-1 group-hover:text-orange transition-colors">{p.data.title}</div>
            <div class="text-xs text-navy/60">{p.data.count} icons · ${p.data.price_usd.toFixed(2)}</div>
          </div>
        </a>
      ))}
    </div>
  </section>
)}
