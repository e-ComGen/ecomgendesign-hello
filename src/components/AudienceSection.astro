---
interface Persona { role: string; pain: string }
interface Props { audience: Persona[] }
const { audience } = Astro.props;
---
<section class="bg-white border-y border-navy/10">
  <div class="max-w-5xl mx-auto px-6 py-14">
    <h2 class="text-2xl font-semibold tracking-tight mb-8">Who this pack is for</h2>
    <div class="grid sm:grid-cols-2 gap-6">
      {audience.map(({ role, pain }) => (
        <div class="border border-navy/10 rounded-xl p-6 bg-bg/40">
          <div class="font-semibold text-navy mb-2">{role}</div>
          <p class="text-navy/70 text-sm leading-relaxed">{pain}</p>
        </div>
      ))}
    </div>
  </div>
</section>
